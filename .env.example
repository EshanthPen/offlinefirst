# ── Core ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
DB_PATH=./offlinefirst.db
# CLIENT_DIST=/app/client/dist

# ── Auth (optional but recommended in prod) ────────────────────
TEACHER_PIN=
AUTH_SECRET=

# ── CORS (optional) ────────────────────────────────────────────
ALLOWED_ORIGINS=

# ── Daily backup (enabled by default) ──────────────────────────
# Local backups: a JSON snapshot is written every N hours to BACKUP_DIR
# (defaults to <DB_PATH parent>/backups). Last 14 kept, older pruned.
# Set to 0 to disable.
BACKUP_INTERVAL_HOURS=24
# BACKUP_DIR=/var/data/backups

# ── Optional S3-compatible upload of each backup ───────────────
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO.
# All four must be set to enable upload.
# S3_BUCKET=offlinefirst-backups
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Branding (optional) ────────────────────────────────────────
# SCHOOL_NAME shows in onboarding + topbar for multi-tenant deploys.
# SCHOOL_NAME=Ada Academy
