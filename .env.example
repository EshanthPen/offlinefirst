# Port the Express server listens on (Render/Railway/Fly set this automatically).
PORT=3001

# Set to "production" in deployed environments.
NODE_ENV=development

# SQLite database file path. On hosts with persistent disks, point this at the mount.
# Render example: /var/data/offlinefirst.db
# Fly.io example: /data/offlinefirst.db
DB_PATH=./offlinefirst.db

# Optional override for the built frontend directory.
# CLIENT_DIST=/app/client/dist

# ─── PRODUCTION HARDENING ──────────────────────────────────────────────
# All four are OPTIONAL. The app runs without them (back-compat) but
# is fully open. Set them in production.

# Teacher PIN — gates the Teacher view + lesson writes + backup/restore.
# 4–10 digits. If unset, anyone can edit lessons.
TEACHER_PIN=

# Signing secret for the auth token. 32+ random bytes (hex).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a random one is generated at boot (invalidates sessions on restart).
AUTH_SECRET=

# CORS allowlist — comma-separated origins. If unset, all origins allowed.
# Example: ALLOWED_ORIGINS=https://offlinefirst.org,https://www.offlinefirst.org
ALLOWED_ORIGINS=
